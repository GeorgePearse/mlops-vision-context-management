    "eslint": "9.39.1",
    "eslint-plugin-svelte": "3.15.2",
    "globals": "17.4.0",
    "oxlint": "1.58.0",
    "svelte": "5.54.0",
    "svelte-check": "4.4.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.55.0",
    "vite": "7.3.1"
